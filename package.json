{
  "name": "upshift-cli",
  "version": "0.5.4",
  "description": "AI-powered dependency upgrades with explanations and safe rollbacks.",
  "type": "module",
  "bin": {
    "upshift": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repairman29/upshift-cli.git"
  },
  "homepage": "https://upshiftai.dev",
  "bugs": {
    "url": "https://github.com/repairman29/upshift-cli/issues"
  },
  "keywords": [
    "dependencies",
    "upgrade",
    "security",
    "vulnerabilities",
    "npm",
    "yarn",
    "pnpm",
    "cli",
    "ai"
  ],
  "author": "Jeff Adkins",
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "node --loader ts-node/esm src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:corpus": "npm run build && node scripts/corpus-smoke.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.3.0",
    "chalk-animation": "^2.0.3",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "inquirer": "^13.3.0",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "semver": "^7.7.4",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "migrations",
    "pricing.json"
  ]
}
